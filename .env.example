# ============================================================
#  CONFIGURACION - copia este archivo a ".env" y pon tu API key
# ============================================================

# >>> LO UNICO OBLIGATORIO: tu API key de DeepSeek <<<
DEEPSEEK_API_KEY=pon-aqui-tu-api-key

# Opcionales (ya tienen valores por defecto que funcionan)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Base de datos de la PLATAFORMA (SQLite, no requiere instalar nada)
DATABASE_URL="file:./dev.db"

# Puerto base donde se exponen las apps generadas por Docker
# El frontend usa este puerto, el backend usa GENERATED_BASE_PORT+1
GENERATED_BASE_PORT=8080
