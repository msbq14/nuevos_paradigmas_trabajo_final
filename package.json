{
  "name": "mdd-pipeline",
  "version": "1.0.0",
  "private": true,
  "description": "Orquestador MDD asistido por IA: lenguaje natural -> CIM -> PIM -> PSM -> codigo -> Docker",
  "scripts": {
    "predev": "prisma generate && prisma db push --skip-generate --accept-data-loss",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "go": "prisma generate && prisma db push --skip-generate --accept-data-loss && next build && next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3"
  }
}
